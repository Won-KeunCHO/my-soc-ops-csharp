@using SocOps.Models

<section class="screen screen-start">
    <div class="ambient-glow"></div>
    <div class="floating-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
        <div class="shape shape-4"></div>
    </div>

    <div class="landing-container rise-in">
        <div class="hero-section">
            <div class="badge-pill">🎲 Social Mixer Game</div>
            
            <h1 class="brand-title">
                <span class="title-word">Break</span>
                <span class="title-word">the</span>
                <span class="title-word">Ice</span>
            </h1>
            
            <p class="brand-tagline">Find your people. Get five in a row. Make networking fun.</p>

            <div class="cta-button-group">
                <button @onclick="() => HandleStart(QuestionTheme.Pokemon)" class="btn btn-primary btn-pulse">
                    <span class="btn-text">Play Now</span>
                    <span class="btn-icon">→</span>
                </button>
            </div>
        </div>

        <div class="theme-selector">
            <p class="theme-selector-label">or choose a theme:</p>
            <div class="theme-buttons">
                <button @onclick="() => HandleStart(QuestionTheme.Pokemon)" 
                        class="theme-btn @(SelectedTheme == QuestionTheme.Pokemon ? "theme-btn-active" : "")">
                    <span class="theme-icon">🎮</span>
                    <span class="theme-name">Pokémon</span>
                    <span class="theme-desc">Classic</span>
                </button>
                <button @onclick="() => HandleStart(QuestionTheme.TechLife)" 
                        class="theme-btn @(SelectedTheme == QuestionTheme.TechLife ? "theme-btn-active" : "")">
                    <span class="theme-icon">💻</span>
                    <span class="theme-name">Tech Life</span>
                    <span class="theme-desc">New</span>
                </button>
            </div>
        </div>

        <div class="features-grid">
            <div class="feature-card feature-card-1">
                <div class="feature-icon">🎯</div>
                <h3>Match & Mark</h3>
                <p>Find people matching each prompt on your card</p>
            </div>
            <div class="feature-card feature-card-2">
                <div class="feature-icon">⭐</div>
                <h3>Get Five</h3>
                <p>Mark five in a row to win big</p>
            </div>
            <div class="feature-card feature-card-3">
                <div class="feature-icon">🎉</div>
                <h3>Call Bingo</h3>
                <p>Shout bingo and claim your victory</p>
            </div>
        </div>

        <div class="stats-bar">
            <div class="stat-item">
                <span class="stat-number">5×5</span>
                <span class="stat-label">Grid</span>
            </div>
            <div class="stat-item">
                <span class="stat-number">∞</span>
                <span class="stat-label">Players</span>
            </div>
            <div class="stat-item">
                <span class="stat-number">1</span>
                <span class="stat-label">Min</span>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public EventCallback<QuestionTheme> OnStartWithTheme { get; set; }

    public QuestionTheme SelectedTheme { get; private set; } = QuestionTheme.Pokemon;

    private async Task HandleStart(QuestionTheme theme)
    {
        SelectedTheme = theme;
        await OnStartWithTheme.InvokeAsync(theme);
    }
}
