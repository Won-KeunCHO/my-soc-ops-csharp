@using SocOps.Models

<section class="screen screen-game">
    <div class="game-shell rise-in">
        <header class="game-header glass-panel">
            <button @onclick="OnReset" class="apple-button apple-button-ghost" aria-label="Back to start">
                Back
            </button>
            <h1>Soc Ops</h1>
            <div class="header-spacer" aria-hidden="true"></div>
        </header>

        <p class="game-instructions">Tap a square when you find someone who matches it.</p>

        @if (HasBingo)
        {
            <div class="bingo-banner" role="status" aria-live="polite">
                BINGO! You completed a line.
            </div>
        }

        <div class="board-wrap">
            <BingoBoard Board="@Board" WinningSquareIds="@WinningSquareIds" OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</section>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
