<div class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="bingo-title">
    <div class="bingo-modal glass-panel pop-in">
        <p class="eyebrow">Achievement Unlocked</p>
        <h2 id="bingo-title">BINGO</h2>
        <p>You completed a full line. Keep going and fill the board.</p>

        <button @onclick="OnDismiss" class="apple-button apple-button-primary">
            Continue
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
